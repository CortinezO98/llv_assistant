# ── APP ──────────────────────────────────────────────────────────────
APP_NAME=LLV Assistant
APP_ENV=development        # development | production
APP_DEBUG=true
SECRET_KEY=CAMBIA_ESTO_POR_UNA_CLAVE_SECRETA_LARGA_Y_ALEATORIA
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── BASE DE DATOS ────────────────────────────────────────────────────
DB_HOST=db                 # 'db' en Docker, 'localhost' en local sin Docker
DB_PORT=3306
DB_NAME=llv_assistant
DB_USER=llv_user
DB_PASSWORD=llv_password
DB_ROOT_PASSWORD=rootpassword

# ── GOOGLE GEMINI AI ─────────────────────────────────────────────────
# Obtener en: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=TU_GEMINI_API_KEY_AQUI
GEMINI_MODEL=gemini-2.5-flash

# ── WHATSAPP BUSINESS API (META) ─────────────────────────────────────
# Obtener en: https://developers.facebook.com/apps/
WHATSAPP_TOKEN=TU_ACCESS_TOKEN_META_AQUI
WHATSAPP_PHONE_NUMBER_ID=TU_PHONE_NUMBER_ID_AQUI
WHATSAPP_BUSINESS_ACCOUNT_ID=TU_WABA_ID_AQUI
WEBHOOK_VERIFY_TOKEN=llv_webhook_verify_2024   # Token personalizado para verificar webhook

# ── PLAN Y ALERTAS ───────────────────────────────────────────────────
PLAN_MONTHLY_LIMIT=1500
ALERT_EMAIL_80_PERCENT=true
ALERT_EMAIL_100_PERCENT=true
ADMIN_ALERT_EMAIL=tu_correo@ejemplo.com

# ── SMTP (para alertas de consumo) ───────────────────────────────────
# Puedes usar Gmail, SendGrid, etc.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_correo@gmail.com
SMTP_PASSWORD=tu_app_password_gmail
SMTP_FROM_NAME=LLV Assistant Sistema

# ── PAGOS ─────────────────────────────────────────────────────────────
# Configurar según la pasarela que use el cliente
DEFAULT_PAYMENT_METHOD=zelle   # zelle | ath | paypal | wompi | payU

# ── VAGARO (fase 2 — dejar vacío en Fase 1) ──────────────────────────
VAGARO_API_KEY=
VAGARO_MERCHANT_ID=

# ── WORKERS ──────────────────────────────────────────────────────────
CONVERSATION_WORKER_INTERVAL=5    # segundos entre ciclos del worker
CONVERSATION_WORKER_BATCH=10      # mensajes por ciclo
